{
  "version": 3,
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "api/index.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ]
}
